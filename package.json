{
  "name": "onestopservice",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "pythonw backend/main.py",
    "dev:all": "concurrently -n vite,python -c cyan,green \"vite\" \"pythonw backend/main.py\"",
    "dev:all:verbose": "concurrently -n vite,python -c cyan,green \"vite\" \"python backend/main.py\"",
    "build": "vite build",
    "build:backend": "pyinstaller --onefile --name onestopservice-backend --distpath src-tauri/resources --noconsole backend/main.py",
    "build:all": "npm run build && npm run build:backend",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "element-plus": "^2.14.2",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^10.0.3",
    "vite": "^6.0.3"
  }
}
