{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "onestopservice",
  "version": "0.1.0",
  "identifier": "com.tzy88.onestopservice",
  "build": {
    "beforeDevCommand": "npm run dev:all",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:all",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OneStopService - 本地服务一条龙管理",
        "width": 960,
        "height": 640,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/onestopservice-backend.exe"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
